rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net - default deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Core reusable helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    // 1. Reviews Collection Rules
    match /reviews/{reviewId} {
      allow get, list: if true; // Public reviews can be read by anyone
      
      allow create: if isValidId(reviewId) 
        && request.resource.data.keys().hasAll(['name', 'role', 'rating', 'comment', 'date', 'avatar'])
        && request.resource.data.keys().size() == 6
        && request.resource.data.name is string && request.resource.data.name.size() <= 100
        && request.resource.data.role is string && request.resource.data.role.size() <= 50
        && request.resource.data.rating is number && request.resource.data.rating >= 1 && request.resource.data.rating <= 5
        && request.resource.data.comment is string && request.resource.data.comment.size() <= 10000
        && request.resource.data.date is string && request.resource.data.date.size() <= 50
        && request.resource.data.avatar is string && request.resource.data.avatar.size() <= 15;
        
      allow update, delete: if false; // Secure: Reviews cannot be altered or deleted from the client SDK
    }
    
    // 2. Bookings Collection Rules
    match /bookings/{bookingId} {
      allow get: if true; // Direct access to individual bookings (e.g., ticket page lookup) is allowed
      allow list: if false; // Blanket queries disallowed to protect customer privacy
      
      allow create: if isValidId(bookingId)
        && request.resource.data.keys().hasAll([
          'clientName', 'clientEmail', 'clientPhone', 'eventDate', 'eventType', 
          'guestCount', 'selectedPackageId', 'selectedServices', 'customMessage', 
          'estimatedCost', 'bookingRef', 'timestamp', 'customMenu'
        ])
        && request.resource.data.clientName is string && request.resource.data.clientName.size() <= 150
        && request.resource.data.clientEmail is string && request.resource.data.clientEmail.size() <= 150
        && request.resource.data.clientPhone is string && request.resource.data.clientPhone.size() <= 30
        && request.resource.data.eventDate is string && request.resource.data.eventDate.size() <= 50
        && request.resource.data.eventType is string && request.resource.data.eventType.size() <= 50
        && request.resource.data.guestCount is number
        && request.resource.data.selectedPackageId is string && request.resource.data.selectedPackageId.size() <= 100
        && request.resource.data.selectedServices is list
        && request.resource.data.customMessage is string && request.resource.data.customMessage.size() <= 10000
        && request.resource.data.estimatedCost is number
        && request.resource.data.bookingRef is string && request.resource.data.bookingRef.size() <= 30
        && request.resource.data.timestamp is string && request.resource.data.timestamp.size() <= 50
        && request.resource.data.customMenu is list;
        
      allow update, delete: if false; // Customers cannot manipulate or delete active booking logs
    }
  }
}
